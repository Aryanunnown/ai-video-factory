datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model VideoJob {
  id          String   @id @default(cuid())

  topic       String

  title       String?

  notes       String?

  status      String   @default("PENDING")

  scriptJson  Json?

  audioUrl    String?

  finalVideo  String?

  createdAt   DateTime @default(now())

  scenes Scene[]
}

model Scene {
  id         String @id @default(cuid())

  jobId      String

  orderNo    Int

  text       String

  visual     String

  duration   Int

  status     String @default("PENDING")

  videoJob VideoJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}